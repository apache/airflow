# Runs the internal development MCP server, exposing the breeze Airflow instance's REST
# API to MCP-capable coding agents. Started as an mprocs/tmux pane when breeze is launched
# with `start-airflow --mcp-server`.

echo "Waiting for the API server to be ready on localhost:8080..."
while ! nc -z localhost 8080; do
    sleep 1
done
echo "API server is ready. Starting the MCP server."

export AIRFLOW_API_URL="http://localhost:8080"
export AIRFLOW_MCP_ALLOW_WRITES="${AIRFLOW_MCP_ALLOW_WRITES:-true}"

# Run via `uvx` from the mounted sources: it builds the server in its own isolated,
# ephemeral environment, so it works regardless of whether the prebuilt CI image already
# carries fastmcp and never installs anything into the mounted /opt/airflow checkout.
exec uvx --from /opt/airflow/dev/mcp_server airflow-dev-mcp --transport http --host 0.0.0.0 --port 8081
