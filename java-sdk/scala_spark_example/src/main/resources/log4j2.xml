<!--
  Routes Log4j 2 logging (the Scala Spark tasks and Spark's own loggers) into
  Airflow's task logs through the AirflowAppender provided by airflow-sdk-log4j2.
  Spark loggers are pinned to WARN so the task output stays readable.
-->
<Configuration status="WARN" packages="org.apache.airflow.sdk.log4j">
  <Appenders>
    <AirflowAppender name="Airflow"/>
  </Appenders>
  <Loggers>
    <Logger name="org.apache.spark" level="warn"/>
    <Logger name="org.sparkproject" level="warn"/>
    <Logger name="org.apache.hadoop" level="warn"/>
    <Root level="info">
      <AppenderRef ref="Airflow"/>
    </Root>
  </Loggers>
</Configuration>
