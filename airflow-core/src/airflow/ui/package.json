{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "homepage": "/ui",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "lint": "eslint --quiet && tsc --p tsconfig.app.json",
    "lint:fix": "eslint --fix && tsc --p tsconfig.app.json",
    "format": "pnpm prettier --write .",
    "preview": "vite preview",
    "codegen": "openapi-merge-cli && openapi-rq -i openapi.merged.json -c axios --format prettier -o openapi-gen --operationId",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install"
  },
  "dependencies": {
    "@chakra-ui/anatomy": "^2.3.4",
    "@chakra-ui/react": "^3.33.0",
    "@codemirror/lang-json": "^6.0.2",
    "@emotion/react": "^11.14.0",
    "@guanmingchiu/sqlparser-ts": "^0.61.1",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@uiw/codemirror-themes-all": "^4.25.5",
    "@uiw/react-codemirror": "^4.25.5",
    "@visx/group": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@xyflow/react": "^12.10.1",
    "anser": "^2.3.5",
    "axios": "^1.13.5",
    "chakra-react-select": "^6.1.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-dayjs-4": "^1.0.4",
    "chartjs-plugin-annotation": "^3.1.0",
    "dayjs": "^1.11.19",
    "elkjs": "^0.11.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-hotkeys-hook": "^5.2.4",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-innertext": "^1.1.5",
    "react-json-view": "^1.21.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "use-debounce": "^10.1.0",
    "usehooks-ts": "^3.1.1",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@7nohe/openapi-react-query-codegen": "^2.0.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "msw": "^2.12.10",
    "openapi-merge-cli": "^1.3.2",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "^4.0.18",
    "web-worker": "^1.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "msw"
    ],
    "overrides": {
      "tar@<=7.5.3": ">=7.5.4",
      "tar@<7.5.7": ">=7.5.7",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "prismjs@<1.30.0": ">=1.30.0",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0"
    }
  }
}
